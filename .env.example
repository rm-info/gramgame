# À copier en `.env` puis remplir avec les valeurs de votre projet Supabase.
# Récupérables dans Supabase → Settings → API Keys → "Publishable key".
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Pour le build CI vers GitHub Pages :
# BASE_PATH=/gramgame
